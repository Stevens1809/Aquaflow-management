<?xml version="1.0" encoding="utf-8"?>
<!--
    colors.xml (values-night) — Palette de couleurs du mode SOMBRE
    Android charge automatiquement ce fichier quand le thème sombre est actif
    Les noms doivent être identiques à values/colors.xml
-->
<resources>
    <color name="fond_application">#0A1929</color>
    <color name="fond_carte">#0D2137</color>
    <!-- Cartes en mode nuit : alpha D0 = 82% pour laisser plus ressortir le fond sombre -->
    <color name="carte_verre">#D00D2137</color>
    <color name="carte_verre_bleu">#D0102840</color>
    <color name="carte_verre_panneau_sombre">#D0061825</color>
    <color name="texte_principal">#E8F0FE</color>
    <color name="texte_secondaire">#8BA4BE</color>
    <color name="accent_bleu">#00BCD4</color>
    <color name="accent_bleu_clair">#1A3D48</color>
    <color name="accent_vert">#10B981</color>
    <color name="accent_jaune">#F59E0B</color>
    <color name="accent_rouge">#EF4444</color>
    <!-- Bordures nuit : cyan légèrement plus visible pour détacher les cartes du fond sombre -->
    <color name="contour_carte">#3000BCD4</color>
    <color name="contour_carte_bleu">#5000BCD4</color>
    <color name="fond_nav_clair">#0A1929</color>
    <color name="nav_inactif_clair">#A0A0A0</color>
    <color name="fond_nav_sombre">#0A1929</color>
    <color name="nav_inactif_sombre">#A0A0A0</color>
    <color name="nav_actif">#00A3FF</color>
    <color name="texte_succes">#34D399</color>
    <color name="fond_succes_clair">#0D2E1F</color>
    <color name="contour_succes">#1A5C3A</color>
    <color name="fond_info">#0D2137</color>
    <!-- Alias de compatibilité (identiques à values/colors.xml) -->
    <color name="bg_app">@color/fond_application</color>
    <color name="bg_card">@color/fond_carte</color>
    <color name="card_glass">@color/carte_verre</color>
    <color name="card_glass_blue">@color/carte_verre_bleu</color>
    <color name="card_glass_dark_panel">@color/carte_verre_panneau_sombre</color>
    <color name="text_main">@color/texte_principal</color>
    <color name="text_sub">@color/texte_secondaire</color>
    <color name="accent_blue">@color/accent_bleu</color>
    <color name="accent_blue_light">@color/accent_bleu_clair</color>
    <color name="accent_green">@color/accent_vert</color>
    <color name="accent_yellow">@color/accent_jaune</color>
    <color name="accent_red">@color/accent_rouge</color>
    <color name="card_stroke">@color/contour_carte</color>
    <color name="card_stroke_blue">@color/contour_carte_bleu</color>
    <color name="nav_bg_light">@color/fond_nav_clair</color>
    <color name="nav_item_inactive_light">@color/nav_inactif_clair</color>
    <color name="nav_bg_dark">@color/fond_nav_sombre</color>
    <color name="nav_item_inactive_dark">@color/nav_inactif_sombre</color>
    <color name="nav_active">@color/nav_actif</color>
    <color name="text_success">@color/texte_succes</color>
    <color name="bg_success_light">@color/fond_succes_clair</color>
    <color name="stroke_success">@color/contour_succes</color>
    <color name="bg_info">@color/fond_info</color>
</resources>
