<?xml version="1.0" encoding="utf-8"?>
<!--
    Fond de l'icône adaptative AquaFlow Management
    Dégradé bleu foncé → cyan, évoque l'eau et la technologie
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Rectangle de fond avec dégradé bleu profond → cyan -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0.0" android:color="#FF062A4E"/>
                <item android:offset="0.5" android:color="#FF0A4A7A"/>
                <item android:offset="1.0" android:color="#FF007B9E"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Cercles décoratifs translucides pour donner un effet eau/vague -->
    <path
        android:pathData="M-10,90 Q30,60 70,85 Q90,95 120,80"
        android:strokeWidth="18"
        android:strokeColor="#1A00BCD4"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M-10,100 Q25,75 65,95 Q90,105 120,90"
        android:strokeWidth="14"
        android:strokeColor="#2500BCD4"
        android:fillColor="#00000000"/>
</vector>
